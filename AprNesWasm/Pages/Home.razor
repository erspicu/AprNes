@page "/"
@using System.IO
@using AprNes
@using Microsoft.AspNetCore.Components.Forms
@using Microsoft.JSInterop
@inject IJSRuntime JS
@implements IAsyncDisposable

<div style="font-family:monospace; padding:10px;">
    <h4 style="margin:0 0 8px">🎮 AprNes WASM
        <span style="font-size:10px; color:#666; font-weight:normal; margin-left:8px;">
            build: @AprNes.BuildInfo.Timestamp
        </span>
    </h4>

    @if (!_romLoaded)
    {
        <p style="color:#888; margin:4px 0">選擇 NES ROM 檔案（Mapper 0/1/2/3/4/7/11/66）</p>
        <InputFile OnChange="LoadRom" accept=".nes"
                   style="display:block; margin-bottom:6px;" />
    }
    else
    {
        <div style="margin-bottom:6px;">
            <span style="color:#4a4; font-weight:bold">▶ @_romName</span>
            <button @onclick="StopGame"
                    style="margin-left:12px; padding:2px 10px;">■ 停止</button>
            <span style="color:#888; margin-left:12px; font-size:11px;">@_fps FPS</span>
        </div>
    }

    <!-- NES 畫面 256×240 -->
    <canvas id="nesCanvas" width="256" height="240"
            tabindex="0"
            style="display:block; border:2px solid #555;
                   image-rendering:pixelated; image-rendering:crisp-edges;
                   background:#000; outline:none;"
            @onkeydown="OnKeyDown" @onkeydown:preventDefault="true"
            @onkeyup="OnKeyUp"   @onkeyup:preventDefault="true">
    </canvas>

    @if (_romLoaded)
    {
        <p style="color:#666; font-size:11px; margin:4px 0;">
            鍵盤：Z=A　X=B　Enter=Start　Shift=Select　方向鍵
        </p>
    }
    <div style="margin-top:6px; font-size:12px; color:#aaa; display:flex; gap:16px; align-items:center; flex-wrap:wrap;">
        <label style="cursor:pointer;">
            <input type="checkbox" checked="@_audioEnabled"
                   @onchange="OnAudioToggle" /> 音效
        </label>
        <label style="display:flex; align-items:center; gap:6px; cursor:pointer;">
            🔊
            <input type="range" min="0" max="100" value="@_volume"
                   style="width:80px; cursor:pointer;"
                   @onchange="OnVolumeChange" />
            <span style="min-width:26px;">@_volume%</span>
        </label>
        <label style="cursor:pointer;">
            <input type="checkbox" checked="@_fpsLimit"
                   @onchange="OnFpsLimitToggle" /> 限制 FPS
        </label>
        @if (!_fpsLimit)
        {
            <span style="color:#f80; font-size:11px;">⚡ 無限制</span>
        }
        @if (_gamepadConnected)
        {
            <span style="color:#4a4;">🎮 手把已連接</span>
        }
        else
        {
            <span style="color:#888; font-size:11px;">🎮 無手把（按手把任意鍵偵測）</span>
        }
    </div>
    @if (_errorMsg != null)
    {
        <p style="color:red; margin:4px 0;">⚠️ @_errorMsg</p>
    }
</div>

@code {
    bool   _romLoaded = false;
    string _romName   = "";
    string _errorMsg  = null;
    string _fps       = "0";
    bool   _audioEnabled = true;
    bool   _fpsLimit     = true;
    int    _volume       = 80;   // 0~100
    int    _prevGamepadMask   = 0;
    bool   _gamepadConnected  = false;

    // frame 計數（FPS 顯示用）
    int    _framesSinceLastUpdate = 0;
    long   _lastFpsTickMs         = 0;
    int    _totalFrames           = 0;

    // 音效樣本 buffer（每幀從 StepOneFrame 收集）
    System.Collections.Generic.List<short> _audioSamples
        = new System.Collections.Generic.List<short>(2048);

    // ── ROM 載入 ─────────────────────────────────────────────────────────────
    async System.Threading.Tasks.Task LoadRom(InputFileChangeEventArgs e)
    {
        _errorMsg = null;
        var file  = e.File;
        if (file == null) return;
        _romName = file.Name;

        using var ms = new MemoryStream();
        await file.OpenReadStream(maxAllowedSize: 4 * 1024 * 1024).CopyToAsync(ms);
        byte[] rom = ms.ToArray();

        // 訂閱音效（先解除舊的再重訂，避免重複）
        NesCore.AudioSampleReady -= CollectAudio;
        NesCore.AudioSampleReady += CollectAudio;
        NesCore.OnError = msg => { _errorMsg = msg; InvokeAsync(StateHasChanged); };

        NesCore.WasmInit();

        bool ok = NesCore.init(rom);
        if (!ok)
        {
            _errorMsg = "ROM 初始化失敗（不支援的 Mapper？）";
            await InvokeAsync(StateHasChanged);
            return;
        }

        _romLoaded = true;
        _totalFrames = 0;
        _lastFpsTickMs = System.Environment.TickCount64;
        StateHasChanged();

        await JS.InvokeVoidAsync("nesInterop.init", "nesCanvas");
        var dotNetRef = DotNetObjectReference.Create(this);
        await JS.InvokeVoidAsync("nesInterop.startLoop", dotNetRef);
        await JS.InvokeVoidAsync("nesInterop.focusCanvas");
    }

    void CollectAudio(short s) => _audioSamples.Add(s);

    // ── 每幀由 JS invokeMethod（同步）呼叫 ───────────────────────────────────
    [JSInvokable]
    public void OnFrame()
    {
        if (!_romLoaded || NesCore.exit) return;
        try
        {
            // 執行一幀
            _audioSamples.Clear();

            // 手把輸入（每幀輪詢，差分更新）
            int gpMask = NesJsInterop.GetGamepadState();
            bool nowConnected = gpMask >= 0;
            if (nowConnected != _gamepadConnected)
            {
                _gamepadConnected = nowConnected;
                _ = InvokeAsync(StateHasChanged);
            }
            if (nowConnected)
            {
                for (int i = 0; i < 8; i++)
                {
                    int bit = 1 << i;
                    bool prev = (_prevGamepadMask & bit) != 0;
                    bool curr = (gpMask & bit) != 0;
                    if (prev != curr)
                    {
                        if (curr) NesCore.P1_ButtonPress((byte)i);
                        else      NesCore.P1_ButtonUnPress((byte)i);
                    }
                }
                _prevGamepadMask = gpMask;
            }

            NesCore.StepOneFrame();
            _totalFrames++;

            // 零拷貝畫面輸出（[JSImport] + JSType.MemoryView，直接傳 WASM heap view）
            byte[] rgba = NesCore.GetScreenRgba();
            NesJsInterop.DrawFrame(rgba);

            // 音效（fire-and-forget）
            if (_audioEnabled && _audioSamples.Count > 0)
            {
                var samples = _audioSamples.ToArray();
                _ = JS.InvokeVoidAsync("nesInterop.playAudio", samples).AsTask();
            }

            // FPS 顯示（每秒一次，fire-and-forget）
            _framesSinceLastUpdate++;
            long now = System.Environment.TickCount64;
            if (now - _lastFpsTickMs >= 1000)
            {
                _fps = _framesSinceLastUpdate.ToString();
                _framesSinceLastUpdate = 0;
                _lastFpsTickMs = now;
                _ = InvokeAsync(StateHasChanged);
            }
        }
        catch (Exception ex)
        {
            _errorMsg = $"Frame #{_totalFrames} error: {ex.Message}";
            _ = InvokeAsync(StateHasChanged);
        }
    }

    // ── 選項切換 ─────────────────────────────────────────────────────────────
    async System.Threading.Tasks.Task OnAudioToggle(ChangeEventArgs e)
    {
        _audioEnabled = (bool)e.Value;
    }

    async System.Threading.Tasks.Task OnVolumeChange(ChangeEventArgs e)
    {
        _volume = int.Parse(e.Value.ToString());
        await JS.InvokeVoidAsync("nesInterop.setVolume", _volume / 100.0);
    }

    async System.Threading.Tasks.Task OnFpsLimitToggle(ChangeEventArgs e)
    {
        _fpsLimit = (bool)e.Value;
        await JS.InvokeVoidAsync("nesInterop.setFpsLimit", _fpsLimit);
    }

    // ── 鍵盤輸入 ─────────────────────────────────────────────────────────────    // 索引: 0=A 1=B 2=Select 3=Start 4=Up 5=Down 6=Left 7=Right
    static int KeyToButton(string key) => key switch
    {
        "z" or "Z"   => 0,  // A
        "x" or "X"   => 1,  // B
        "Shift"      => 2,  // Select
        "Enter"      => 3,  // Start
        "ArrowUp"    => 4,
        "ArrowDown"  => 5,
        "ArrowLeft"  => 6,
        "ArrowRight" => 7,
        _            => -1
    };

    void OnKeyDown(KeyboardEventArgs e)
    {
        int btn = KeyToButton(e.Key);
        if (btn >= 0) NesCore.P1_ButtonPress((byte)btn);
    }

    void OnKeyUp(KeyboardEventArgs e)
    {
        int btn = KeyToButton(e.Key);
        if (btn >= 0) NesCore.P1_ButtonUnPress((byte)btn);
    }

    // ── 初始化（頁面渲染後執行一次，注冊手把連接事件回呼）────────────────────
    bool _initialized = false;
    protected override async System.Threading.Tasks.Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender && !_initialized)
        {
            _initialized = true;
            var dotNetRef = DotNetObjectReference.Create(this);
            await JS.InvokeVoidAsync("nesInterop.setGamepadCallback", dotNetRef);
        }
    }

    [JSInvokable]
    public void OnGamepadConnected(string id)
    {
        _gamepadConnected = true;
        _ = InvokeAsync(StateHasChanged);
    }

    [JSInvokable]
    public void OnGamepadDisconnected()
    {
        _gamepadConnected = false;
        _prevGamepadMask  = 0;
        _ = InvokeAsync(StateHasChanged);
    }

    // ── 停止 ─────────────────────────────────────────────────────────────────
    async System.Threading.Tasks.Task StopGame()
    {
        NesCore.exit = true;
        NesCore.AudioSampleReady -= CollectAudio;
        await JS.InvokeVoidAsync("nesInterop.stopLoop");
        _romLoaded       = false;
        _fps             = "0";
        _romName         = "";
        _prevGamepadMask = 0;
        StateHasChanged();
    }

    public async System.Threading.Tasks.ValueTask DisposeAsync()
    {
        NesCore.exit = true;
        NesCore.AudioSampleReady -= CollectAudio;
        await System.Threading.Tasks.Task.CompletedTask;
    }
}

