<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="AprNesAvalonia.Views.RomInfoWindow"
        Title="ROM File information"
        Width="380" Height="220"
        CanResize="False"
        WindowStartupLocation="CenterOwner"
        Background="#F0F0F0">

    <Grid RowDefinitions="*,Auto" Margin="8">
        <TextBox Grid.Row="0"
                 x:Name="TxtInfo"
                 Text="No load Rom !"
                 IsReadOnly="True"
                 AcceptsReturn="True"
                 TextWrapping="Wrap"
                 Background="White"
                 BorderThickness="1" />
        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right"
                    Spacing="8" Margin="0,8,0,0">
            <Button x:Name="BtnCopy" Content="Copy"  Padding="20,4" Click="BtnCopy_Click"/>
            <Button x:Name="BtnOK"   Content="OK"    Padding="20,4" Click="BtnOK_Click"/>
        </StackPanel>
    </Grid>
</Window>
