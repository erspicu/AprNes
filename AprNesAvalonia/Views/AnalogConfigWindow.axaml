<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="AprNesAvalonia.Views.AnalogConfigWindow"
        Title="Analog Video Settings"
        Width="520" Height="620"
        CanResize="False"
        WindowStartupLocation="CenterOwner"
        Background="#F0F0F0">

    <Grid RowDefinitions="Auto,*,Auto" Margin="8">

        <!-- Preset row -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="8" Margin="0,0,0,8">
            <TextBlock x:Name="LblPreset" Text="Feature Profile" VerticalAlignment="Center"/>
            <ComboBox x:Name="CmbPreset" Width="200" SelectedIndex="0">
                <ComboBoxItem x:Name="CmbPresetChoose" Content="-- Choose --"/>
                <ComboBoxItem x:Name="CmbPresetNtsc"   Content="NTSC Only"/>
                <ComboBoxItem x:Name="CmbPresetCrt"    Content="CRT Only"/>
                <ComboBoxItem x:Name="CmbPresetBoth"   Content="NTSC + CRT"/>
            </ComboBox>
        </StackPanel>

        <TabControl Grid.Row="1">

            <!-- NTSC -->
            <TabItem x:Name="TabNtsc" Header="NTSC">
                <ScrollViewer>
                <StackPanel Margin="8" Spacing="6">
                    <CheckBox x:Name="ChkHBI" Content="HBI Simulation"/>
                    <CheckBox x:Name="ChkColorBurstJitter" Content="Color Burst Jitter"/>
                    <CheckBox x:Name="ChkSymmetricIQ" Content="Symmetric I/Q"/>

                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <CheckBox x:Name="ChkRinging" Content="Ringing"/>
                        <Slider x:Name="SliderRinging" Minimum="0" Maximum="100" Value="30" Width="200"
                                TickFrequency="1" IsSnapToTickEnabled="True"/>
                        <TextBlock x:Name="LblRinging" Text="0.30" VerticalAlignment="Center" MinWidth="40"/>
                    </StackPanel>

                    <Separator/>

                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <TextBlock x:Name="LblGammaLabel" Text="Gamma" VerticalAlignment="Center" MinWidth="50"/>
                        <Slider x:Name="SliderGamma" Minimum="0" Maximum="100" Value="23" Width="200"
                                TickFrequency="1" IsSnapToTickEnabled="True"/>
                        <TextBlock x:Name="LblGamma" Text="0.230" VerticalAlignment="Center" MinWidth="40"/>
                    </StackPanel>

                    <Separator/>

                    <TextBlock x:Name="LblColorTemp" Text="Color Temperature" FontWeight="Bold"/>
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <TextBlock Text="R" VerticalAlignment="Center" MinWidth="20"/>
                        <Slider x:Name="SliderTempR" Minimum="0" Maximum="200" Value="100" Width="200"
                                TickFrequency="1" IsSnapToTickEnabled="True"/>
                        <TextBlock x:Name="LblTempR" Text="1.00" VerticalAlignment="Center" MinWidth="40"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <TextBlock Text="G" VerticalAlignment="Center" MinWidth="20"/>
                        <Slider x:Name="SliderTempG" Minimum="0" Maximum="200" Value="100" Width="200"
                                TickFrequency="1" IsSnapToTickEnabled="True"/>
                        <TextBlock x:Name="LblTempG" Text="1.00" VerticalAlignment="Center" MinWidth="40"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <TextBlock Text="B" VerticalAlignment="Center" MinWidth="20"/>
                        <Slider x:Name="SliderTempB" Minimum="0" Maximum="200" Value="100" Width="200"
                                TickFrequency="1" IsSnapToTickEnabled="True"/>
                        <TextBlock x:Name="LblTempB" Text="1.00" VerticalAlignment="Center" MinWidth="40"/>
                    </StackPanel>
                </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- CRT -->
            <TabItem x:Name="TabCrt" Header="CRT">
                <ScrollViewer>
                <StackPanel Margin="8" Spacing="6">
                    <CheckBox x:Name="ChkInterlaceJitter" Content="Interlace Jitter"/>

                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <CheckBox x:Name="ChkVignette" Content="Vignette"/>
                        <Slider x:Name="SliderVignette" Minimum="0" Maximum="100" Value="15" Width="200"
                                TickFrequency="1" IsSnapToTickEnabled="True"/>
                        <TextBlock x:Name="LblVignette" Text="0.15" VerticalAlignment="Center" MinWidth="40"/>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <CheckBox x:Name="ChkShadowMask" Content="Shadow Mask"/>
                        <ComboBox x:Name="CmbShadowMaskMode" Width="120" SelectedIndex="1">
                            <ComboBoxItem Content="None"/>
                            <ComboBoxItem Content="Aperture Grille"/>
                            <ComboBoxItem Content="Shadow Mask"/>
                        </ComboBox>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <TextBlock x:Name="LblMaskStrength" Text="Strength" VerticalAlignment="Center" MinWidth="60"/>
                        <Slider x:Name="SliderShadowMask" Minimum="0" Maximum="100" Value="30" Width="200"
                                TickFrequency="1" IsSnapToTickEnabled="True"/>
                        <TextBlock x:Name="LblShadowMask" Text="0.30" VerticalAlignment="Center" MinWidth="40"/>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <CheckBox x:Name="ChkCurvature" Content="Curvature"/>
                        <Slider x:Name="SliderCurvature" Minimum="0" Maximum="100" Value="12" Width="200"
                                TickFrequency="1" IsSnapToTickEnabled="True"/>
                        <TextBlock x:Name="LblCurvature" Text="0.12" VerticalAlignment="Center" MinWidth="40"/>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <CheckBox x:Name="ChkPhosphor" Content="Phosphor Persistence"/>
                        <Slider x:Name="SliderPhosphor" Minimum="0" Maximum="100" Value="60" Width="200"
                                TickFrequency="1" IsSnapToTickEnabled="True"/>
                        <TextBlock x:Name="LblPhosphor" Text="0.60" VerticalAlignment="Center" MinWidth="40"/>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <CheckBox x:Name="ChkHorizontalBeam" Content="H-Beam"/>
                        <Slider x:Name="SliderHBeam" Minimum="0" Maximum="100" Value="40" Width="200"
                                TickFrequency="1" IsSnapToTickEnabled="True"/>
                        <TextBlock x:Name="LblHBeam" Text="0.40" VerticalAlignment="Center" MinWidth="40"/>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <CheckBox x:Name="ChkConvergence" Content="Convergence"/>
                        <Slider x:Name="SliderConvergence" Minimum="0" Maximum="100" Value="20" Width="200"
                                TickFrequency="1" IsSnapToTickEnabled="True"/>
                        <TextBlock x:Name="LblConvergence" Text="2.0" VerticalAlignment="Center" MinWidth="40"/>
                    </StackPanel>
                </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- Connector -->
            <TabItem x:Name="TabConnector" Header="Connector">
                <ScrollViewer>
                <StackPanel Margin="8" Spacing="6">

                    <!-- RF -->
                    <TextBlock Text="RF" FontWeight="Bold"/>
                    <Grid ColumnDefinitions="80,*,40" RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto" RowSpacing="4" ColumnSpacing="6">
                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Noise"   VerticalAlignment="Center"/>
                        <Slider    Grid.Row="0" Grid.Column="1" x:Name="SlRfNoise"  Minimum="0" Maximum="100" TickFrequency="1" IsSnapToTickEnabled="True"/>
                        <TextBlock Grid.Row="0" Grid.Column="2" x:Name="LblRfNoise" Text="0.04" VerticalAlignment="Center"/>
                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Slew"    VerticalAlignment="Center"/>
                        <Slider    Grid.Row="1" Grid.Column="1" x:Name="SlRfSlew"   Minimum="0" Maximum="100" TickFrequency="1" IsSnapToTickEnabled="True"/>
                        <TextBlock Grid.Row="1" Grid.Column="2" x:Name="LblRfSlew"  Text="0.60" VerticalAlignment="Center"/>
                        <TextBlock Grid.Row="2" Grid.Column="0" Text="Chroma"  VerticalAlignment="Center"/>
                        <Slider    Grid.Row="2" Grid.Column="1" x:Name="SlRfChroma" Minimum="0" Maximum="100" TickFrequency="1" IsSnapToTickEnabled="True"/>
                        <TextBlock Grid.Row="2" Grid.Column="2" x:Name="LblRfChroma" Text="0.10" VerticalAlignment="Center"/>
                        <TextBlock Grid.Row="3" Grid.Column="0" Text="Beam"    VerticalAlignment="Center"/>
                        <Slider    Grid.Row="3" Grid.Column="1" x:Name="SlRfBeam"   Minimum="0" Maximum="200" TickFrequency="1" IsSnapToTickEnabled="True"/>
                        <TextBlock Grid.Row="3" Grid.Column="2" x:Name="LblRfBeam"  Text="1.10" VerticalAlignment="Center"/>
                        <TextBlock Grid.Row="4" Grid.Column="0" Text="Bloom"   VerticalAlignment="Center"/>
                        <Slider    Grid.Row="4" Grid.Column="1" x:Name="SlRfBloom"  Minimum="0" Maximum="100" TickFrequency="1" IsSnapToTickEnabled="True"/>
                        <TextBlock Grid.Row="4" Grid.Column="2" x:Name="LblRfBloom" Text="0.50" VerticalAlignment="Center"/>
                        <TextBlock Grid.Row="5" Grid.Column="0" Text="Bright"  VerticalAlignment="Center"/>
                        <Slider    Grid.Row="5" Grid.Column="1" x:Name="SlRfBright" Minimum="0" Maximum="200" TickFrequency="1" IsSnapToTickEnabled="True"/>
                        <TextBlock Grid.Row="5" Grid.Column="2" x:Name="LblRfBright" Text="1.10" VerticalAlignment="Center"/>
                    </Grid>

                    <Separator/>

                    <!-- AV -->
                    <TextBlock Text="AV (Composite)" FontWeight="Bold"/>
                    <Grid ColumnDefinitions="80,*,40" RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto" RowSpacing="4" ColumnSpacing="6">
                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Noise"   VerticalAlignment="Center"/>
                        <Slider    Grid.Row="0" Grid.Column="1" x:Name="SlAvNoise"  Minimum="0" Maximum="100" TickFrequency="1" IsSnapToTickEnabled="True"/>
                        <TextBlock Grid.Row="0" Grid.Column="2" x:Name="LblAvNoise" Text="0.00" VerticalAlignment="Center"/>
                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Slew"    VerticalAlignment="Center"/>
                        <Slider    Grid.Row="1" Grid.Column="1" x:Name="SlAvSlew"   Minimum="0" Maximum="100" TickFrequency="1" IsSnapToTickEnabled="True"/>
                        <TextBlock Grid.Row="1" Grid.Column="2" x:Name="LblAvSlew"  Text="0.80" VerticalAlignment="Center"/>
                        <TextBlock Grid.Row="2" Grid.Column="0" Text="Chroma"  VerticalAlignment="Center"/>
                        <Slider    Grid.Row="2" Grid.Column="1" x:Name="SlAvChroma" Minimum="0" Maximum="100" TickFrequency="1" IsSnapToTickEnabled="True"/>
                        <TextBlock Grid.Row="2" Grid.Column="2" x:Name="LblAvChroma" Text="0.35" VerticalAlignment="Center"/>
                        <TextBlock Grid.Row="3" Grid.Column="0" Text="Beam"    VerticalAlignment="Center"/>
                        <Slider    Grid.Row="3" Grid.Column="1" x:Name="SlAvBeam"   Minimum="0" Maximum="200" TickFrequency="1" IsSnapToTickEnabled="True"/>
                        <TextBlock Grid.Row="3" Grid.Column="2" x:Name="LblAvBeam"  Text="0.85" VerticalAlignment="Center"/>
                        <TextBlock Grid.Row="4" Grid.Column="0" Text="Bloom"   VerticalAlignment="Center"/>
                        <Slider    Grid.Row="4" Grid.Column="1" x:Name="SlAvBloom"  Minimum="0" Maximum="100" TickFrequency="1" IsSnapToTickEnabled="True"/>
                        <TextBlock Grid.Row="4" Grid.Column="2" x:Name="LblAvBloom" Text="0.25" VerticalAlignment="Center"/>
                        <TextBlock Grid.Row="5" Grid.Column="0" Text="Bright"  VerticalAlignment="Center"/>
                        <Slider    Grid.Row="5" Grid.Column="1" x:Name="SlAvBright" Minimum="0" Maximum="200" TickFrequency="1" IsSnapToTickEnabled="True"/>
                        <TextBlock Grid.Row="5" Grid.Column="2" x:Name="LblAvBright" Text="1.25" VerticalAlignment="Center"/>
                    </Grid>

                    <Separator/>

                    <!-- S-Video -->
                    <TextBlock Text="S-Video" FontWeight="Bold"/>
                    <Grid ColumnDefinitions="80,*,40" RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto" RowSpacing="4" ColumnSpacing="6">
                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Noise"   VerticalAlignment="Center"/>
                        <Slider    Grid.Row="0" Grid.Column="1" x:Name="SlSvNoise"  Minimum="0" Maximum="100" TickFrequency="1" IsSnapToTickEnabled="True"/>
                        <TextBlock Grid.Row="0" Grid.Column="2" x:Name="LblSvNoise" Text="0.00" VerticalAlignment="Center"/>
                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Slew"    VerticalAlignment="Center"/>
                        <Slider    Grid.Row="1" Grid.Column="1" x:Name="SlSvSlew"   Minimum="0" Maximum="100" TickFrequency="1" IsSnapToTickEnabled="True"/>
                        <TextBlock Grid.Row="1" Grid.Column="2" x:Name="LblSvSlew"  Text="0.90" VerticalAlignment="Center"/>
                        <TextBlock Grid.Row="2" Grid.Column="0" Text="Chroma"  VerticalAlignment="Center"/>
                        <Slider    Grid.Row="2" Grid.Column="1" x:Name="SlSvChroma" Minimum="0" Maximum="100" TickFrequency="1" IsSnapToTickEnabled="True"/>
                        <TextBlock Grid.Row="2" Grid.Column="2" x:Name="LblSvChroma" Text="0.45" VerticalAlignment="Center"/>
                        <TextBlock Grid.Row="3" Grid.Column="0" Text="Beam"    VerticalAlignment="Center"/>
                        <Slider    Grid.Row="3" Grid.Column="1" x:Name="SlSvBeam"   Minimum="0" Maximum="200" TickFrequency="1" IsSnapToTickEnabled="True"/>
                        <TextBlock Grid.Row="3" Grid.Column="2" x:Name="LblSvBeam"  Text="0.65" VerticalAlignment="Center"/>
                        <TextBlock Grid.Row="4" Grid.Column="0" Text="Bloom"   VerticalAlignment="Center"/>
                        <Slider    Grid.Row="4" Grid.Column="1" x:Name="SlSvBloom"  Minimum="0" Maximum="100" TickFrequency="1" IsSnapToTickEnabled="True"/>
                        <TextBlock Grid.Row="4" Grid.Column="2" x:Name="LblSvBloom" Text="0.10" VerticalAlignment="Center"/>
                        <TextBlock Grid.Row="5" Grid.Column="0" Text="Bright"  VerticalAlignment="Center"/>
                        <Slider    Grid.Row="5" Grid.Column="1" x:Name="SlSvBright" Minimum="0" Maximum="200" TickFrequency="1" IsSnapToTickEnabled="True"/>
                        <TextBlock Grid.Row="5" Grid.Column="2" x:Name="LblSvBright" Text="1.40" VerticalAlignment="Center"/>
                    </Grid>

                </StackPanel>
                </ScrollViewer>
            </TabItem>

        </TabControl>

        <Button x:Name="BtnOK" Grid.Row="2" Content="OK" Padding="24,6"
                HorizontalAlignment="Right" Margin="0,8,0,0"
                Click="BtnOK_Click"/>
    </Grid>
</Window>
