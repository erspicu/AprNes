<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="AprNesAvalonia.Views.AboutWindow"
        Title="AprNes"
        Width="380" Height="200"
        CanResize="False"
        WindowStartupLocation="CenterOwner"
        Background="#F0F0F0">

    <Grid RowDefinitions="*,Auto" Margin="16">
        <StackPanel Grid.Row="0" Spacing="10" VerticalAlignment="Center">
            <TextBlock x:Name="DescLabel" Text="April Nintendo Entertainment System Emulator" />
            <TextBlock x:Name="AuthorLabel" Text="Author : erspicu_brox" />
            <TextBlock x:Name="VersionLabel" />
            <TextBlock x:Name="SiteLink"
                       Text="Official Site"
                       Foreground="Blue"
                       TextDecorations="Underline"
                       Cursor="Hand"
                       PointerPressed="SiteLink_Click" />
        </StackPanel>
        <Button x:Name="BtnOK" Grid.Row="1" Content="OK" Padding="20,4"
                HorizontalAlignment="Right"
                Click="BtnOK_Click" />
    </Grid>
</Window>
